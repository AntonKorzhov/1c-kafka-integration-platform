# HTTP-сервис 1С. Для Docker Desktop на Windows host.docker.internal указывает на хост.
ONE_C_BASE_URL=http://host.docker.internal/InfoBase/hs/integration
# Apache/XAMPP publication in this assignment accepts Host: localhost.
# Leave empty when the web server accepts host.docker.internal instead.
ONE_C_HOST_HEADER=localhost
ONE_C_FORMS_PATH=forms-ownership
ONE_C_COUNTERPARTIES_PATH=counterparties
ONE_C_TIMEOUT_SECONDS=15

# Kafka: внутри Docker используется kafka:9092; с Windows-хоста — localhost:9094.
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_OWNERSHIP_TOPIC=1c.ownership_forms.v1
KAFKA_COUNTERPARTIES_TOPIC=1c.counterparties.v1
KAFKA_DLQ_TOPIC=1c.integration.dlq.v1
KAFKA_CONSUMER_GROUP=one-c-postgres-sink-v1

POSTGRES_DB=integration
POSTGRES_USER=integration
POSTGRES_PASSWORD=change_me_before_demo
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# pgAdmin web UI (http://localhost:5050). Replace before a public deployment.
PGADMIN_DEFAULT_EMAIL=admin@example.local
PGADMIN_DEFAULT_PASSWORD=change_me_before_demo

# Grafana web UI (http://localhost:3000).
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_before_demo

LOG_LEVEL=INFO
HEALTH_PORT=8080
MAX_RETRIES=5
